#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Cantidad de estudiantes: ";
    cin >> n;

    double *notas = new double[n];

    for (int i = 0; i < n; i++) {
        cout << "Nota del estudiante " << i + 1 << ": ";
        cin >> notas[i];
    }

    double suma = 0, mayor = notas[0], menor = notas[0];

    for (int i = 0; i < n; i++) {
        suma += notas[i];
        if (notas[i] > mayor) mayor = notas[i];
        if (notas[i] < menor) menor = notas[i];
    }

    cout << "Promedio: " << suma / n << endl;
    cout << "Nota mayor: " << mayor << endl;
    cout << "Nota menor: " << menor << endl;

    delete[] notas; // liberar memoria
    return 0;
}


