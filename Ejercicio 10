#include <iostream>
#include <vector>
#include <fstream>
using namespace std;

class Tarea {
public:
    string nombre;
    int prioridad;
    string fecha;
    bool completada;

    Tarea(string n, int p, string f) {
        nombre = n;
        prioridad = p;
        fecha = f;
        completada = false;
    }

    void marcarCompletada() {
        completada = true;
    }

    void mostrar() {
        cout << "Nombre: " << nombre
             << " | Prioridad: " << prioridad
             << " | Fecha: " << fecha
             << " | Estado: " << (completada ? "Completada" : "Pendiente")
             << endl;
    }
};

void guardar(vector<Tarea> tareas) {
    ofstream archivo("tareas.txt");
    for (auto t : tareas) {
        archivo << t.nombre << "," << t.prioridad << "," << t.fecha << "," << t.completada << endl;
    }
    archivo.close();
}

void recomendacion(vector<Tarea> tareas) {
    int pendientes = 0;

    for (auto t : tareas) {
        if (!t.completada) {
            pendientes++;
            if (t.prioridad == 3) {
                cout << " Recomendación: Prioriza la tarea -> " << t.nombre << endl;
            }
        }
    }

    if (pendientes > 3) {
        cout << " Tienes muchas tareas pendientes. Organiza tu tiempo." << endl;
    }
}

int main() {
    vector<Tarea> tareas;
    int op;

    do {
        cout << "\n1. Agregar tarea\n2. Mostrar tareas\n3. Guardar\n4. Recomendación\n0. Salir\nOpción: ";
        cin >> op;

        if (op == 1) {
            string nombre, fecha;
            int prioridad;

            cout << "Nombre: ";
            cin.ignore();
            getline(cin, nombre);

            cout << "Prioridad (1-3): ";
            cin >> prioridad;

            cout << "Fecha límite: ";
            cin >> fecha;

            tareas.push_back(Tarea(nombre, prioridad, fecha));
        }

        if (op == 2) {
            for (auto &t : tareas) {
                t.mostrar();
            }
        }

        if (op == 3) {
            guardar(tareas);
        }

        if (op == 4) {
            recomendacion(tareas);
        }

    } while (op != 0);

    return 0;
}
